MONGO_URI=""
JWT_SECRET=""
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is auto-injected by Render — do NOT set it manually in production
PORT=5000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Local frontend URL
FRONTEND_URL="http://localhost:5173"
# Production frontend URL (Vercel)
FRONTEND_URL_PROD="https://your-app.vercel.app"

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Leave blank to use in-memory rate limiter (fine for single-instance deploys)
# Set to your Redis URL if you have Redis (e.g., Render Redis, Upstash, etc.)
# REDIS_URL=redis://localhost:6379

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="IMS System"
SMTP_FROM_EMAIL="noreply@ims.com"

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on Render
NODE_ENV=development
